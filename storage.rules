rules_version = '2';

// Deploy with: npm run firebase:deploy:storage
// Matches paths used in OpportunityService: opportunities/{userId}/{opportunityId}/...
service firebase.storage {
  match /b/{bucket}/o {
    match /opportunities/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
